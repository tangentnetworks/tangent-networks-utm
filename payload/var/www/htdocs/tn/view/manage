              <div class="mb-2 text-xs font-bold tracking-wider text-gray-500 uppercase dark:text-gray-400">Cache Size</div>
              <div class="text-lg font-bold text-gray-900 dark:text-white" id="cache-size">--</div>
            </div>
            <!-- BEGIN: Uptime -->
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900">
              <div class="mb-2 text-xs font-bold tracking-wider text-gray-500 uppercase dark:text-gray-400">Uptime</div>
              <div class="text-lg font-bold text-gray-900 dark:text-white" id="uptime">--</div>
            </div>
            <!-- BEGIN: Rate Limited -->
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900">
              <div class="mb-2 text-xs font-bold tracking-wider text-gray-500 uppercase dark:text-gray-400">Rate Limited</div>
              <div class="text-lg font-bold text-orange-600 dark:text-orange-400" id="ratelimited">--</div>
            </div>
            <!-- BEGIN: Recursion -->
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900">
              <div class="mb-2 text-xs font-bold tracking-wider text-gray-500 uppercase dark:text-gray-400">Recursion</div>
              <div class="text-lg font-bold text-gray-900 dark:text-white" id="recursion">--</div>
            </div>
            <!-- BEGIN: Avg Response -->
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900">
              <div class="mb-2 text-xs font-bold tracking-wider text-gray-500 uppercase dark:text-gray-400">Avg Response</div>
              <div class="text-lg font-bold text-purple-600 dark:text-purple-400" id="avg-response">--</div>
            </div>
          </div>
        </div>
        <!-- BEGIN: DNS Lookup Test -->
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="border-b border-gray-200 p-4 dark:border-gray-700">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">DNS Lookup Test</h3>
          </div>
          <div class="p-4">
            <div class="mb-3 flex space-x-2">
              <input type="text" id="test-domain-input" placeholder="example.com" class="flex-1 rounded-lg border border-gray-300 bg-white p-2.5 font-mono text-sm text-gray-900 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 dark:border-gray-600 dark:bg-gray-900 dark:text-white dark:focus:border-blue-400" />
              <button class="rounded-lg bg-blue-700 px-4 py-2.5 text-xs font-medium text-white uppercase shadow-sm transition-all hover:bg-blue-800 hover:shadow-md dark:bg-blue-600 dark:hover:bg-blue-700" data-action="test-lookup">Lookup</button>
            </div>
            <div class="min-h-[100px] rounded-lg border border-gray-200 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900" id="lookup-result">
              <div class="text-sm text-gray-500 dark:text-gray-400">Enter a domain and click Lookup to test DNS resolution</div>
            </div>
          </div>
        </div>
      </div>
      <!-- BEGIN: RIGHT COLUMN: Cache Management & Controls -->
      <div class="space-y-4">
        <!-- BEGIN: Cache Management -->
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="border-b border-gray-200 px-4 py-3 dark:border-gray-700">
            <h3 class="text-base font-bold tracking-tight text-gray-900 dark:text-white">Cache Management</h3>
            <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">Manage DNS cache operations</p>
          </div>
          <hr class="h-px my-8 bg-neutral-quaternary border-b">
          <div class="space-y-4 p-4">
            <!-- BEGIN: Purge All Cache -->
            <div class="space-y-2">
              <label class="mb-1.5 block text-xs font-semibold tracking-wide text-gray-700 uppercase dark:text-gray-300">Full Cache Purge</label>
              <button class="w-32 rounded-lg bg-red-600 px-4 py-1.5 text-xs font-semibold tracking-wide text-white uppercase shadow-sm transition-all hover:bg-red-700 hover:shadow dark:bg-red-500 dark:hover:bg-red-600" data-action="purge-cache">Purge Cache</button>
              <p class="mt-1.5 text-[11px] text-gray-500 dark:text-gray-400">Clear all cached DNS records</p>
            </div>
            <hr class="h-px my-8 bg-neutral-quaternary border-b">
            <!-- BEGIN: Flush Specific Domain -->
            <div class="space-y-2">
              <label class="mb-1.5 block text-xs font-semibold tracking-wide text-gray-700 uppercase dark:text-gray-300">Flush Domain</label>
              <div class="mb-2.5">
                <input type="text" id="flush-domain-input" placeholder="example.com" class="w-full rounded-lg border border-gray-300 bg-white px-3 py-1.5 font-mono text-sm text-gray-900 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/20 dark:border-gray-600 dark:bg-gray-900 dark:text-gray-100 dark:focus:border-blue-400" />
              </div>
              <button class="w-32 rounded-lg bg-green-600 px-4 py-1.5 text-xs font-semibold tracking-wide text-white uppercase shadow-sm transition-all hover:bg-green-700 hover:shadow dark:bg-green-500 dark:hover:bg-green-600" data-action="flush-domain">Flush Domain</button>
              <p class="mt-1.5 text-[11px] text-gray-500 dark:text-gray-400">Clear cache for specific domain</p>
            </div>
            <hr class="h-px my-8 bg-neutral-quaternary border-b">
            <!-- BEGIN: Dump Cache -->
            <div class="space-y-2">
              <label class="mb-1.5 block text-xs font-semibold tracking-wide text-gray-700 uppercase dark:text-gray-300">Export Cache</label>
              <button class="w-32 rounded-lg bg-blue-700 px-4 py-1.5 text-xs font-semibold tracking-wide text-white uppercase shadow-sm transition-all hover:bg-blue-800 hover:shadow dark:bg-blue-600 dark:hover:bg-blue-700" data-action="dump-cache">Export Cache</button>
              <p class="mt-1.5 text-[11px] text-gray-500 dark:text-gray-400">Export cache contents to file</p>
            </div>
          </div>
        </div>
        <!-- BEGIN: Service Control -->
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="border-b border-gray-200 px-4 py-3 dark:border-gray-700">
            <h3 class="text-base font-bold tracking-tight text-gray-900 dark:text-white">Service Control</h3>
            <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">Manage Unbound service state</p>
          </div>
          <hr class="h-px my-8 bg-neutral-quaternary border-b">
          <div class="space-y-4 p-4">
            <!-- BEGIN: Reload Config -->
            <div class="space-y-2">
              <label class="mb-1.5 block text-xs font-semibold tracking-wide text-gray-700 uppercase dark:text-gray-300">Reload Configuration</label>
              <button class="w-32 rounded-lg bg-green-600 px-4 py-1.5 text-xs font-semibold tracking-wide text-white uppercase shadow-sm transition-all hover:bg-green-700 hover:shadow dark:bg-green-500 dark:hover:bg-green-600" data-action="reload-unbound">Reload Service</button>
              <p class="mt-1.5 text-[11px] text-gray-500 dark:text-gray-400">Reload config without service interruption</p>
            </div>
            <hr class="h-px my-8 bg-neutral-quaternary border-b">
            <!-- BEGIN: Info Box -->
            <div class="rounded-lg bg-blue-50 p-3.5 dark:bg-gray-800">
              <p class="text-xs font-medium text-gray-700 dark:text-gray-300">Upstream Configuration</p>
              <p class="mt-0.5 text-[11px] text-gray-600 dark:text-gray-400">Quad9 DNS-over-TLS (9.9.9.11) with threat blocking, DNSSEC, and ECS enabled.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
