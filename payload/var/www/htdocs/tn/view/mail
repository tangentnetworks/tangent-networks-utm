<!-- BEGIN: Mail View -->
<div id="mail-view-wrapper" class="container mx-auto p-4">
  <!--BEGIN: Header Section -->
  <div class="mb-6 flex items-center justify-between">
    <div class="flex items-center">
      <div class="rounded-lg bg-green-600 p-2.5 text-white">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="M22 7l-8.97 5.7a2 2 0 0 1-2.06 0L2 7" />
        </svg>
      </div>
      <div class="ms-3">
        <h1 class="text-2xl leading-tight font-bold tracking-tight text-gray-900 dark:text-white">System Mailbox</h1>
        <p class="text-sm text-gray-600 opacity-60 dark:text-gray-400">Notifications from cron daemon.</p>
      </div>
    </div>
    <div class="flex items-center">
      <button id="refresh-mail-btn" title="Refresh" class="inline-flex items-center justify-center rounded-md bg-blue-700 p-2 text-white transition hover:bg-blue-600 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:outline-none">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
          <path d="M21 2v6h-6" />
          <path d="M3 12a9 9 0 0 1 15-6.7L21 8" />
          <path d="M3 22v-6h6" />
          <path d="M21 12a9 9 0 0 1-15 6.7L3 16" />
        </svg>
      </button>
    </div>
  </div>
  <!--END: Header Section -->
  <!--BEGIN: Stats Cards -->
  <div class="mb-6 grid w-full grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div class="card rounded-xl border border-l-4 border-gray-200 border-l-blue-400 bg-white p-4 shadow-lg dark:border-gray-700 dark:bg-gray-800">
      <div class="mb-1 text-sm text-gray-600 dark:text-gray-400">Total</div>
      <div id="stat-total" class="text-2xl font-bold text-gray-900 dark:text-white">0</div>
    </div>
    <div class="card rounded-xl border border-l-4 border-gray-200 border-l-blue-400 bg-white p-4 shadow-lg dark:border-gray-700 dark:bg-gray-800">
      <div class="mb-1 text-sm text-gray-600 dark:text-gray-400">Unread</div>
      <div id="stat-unread" class="text-2xl font-bold text-gray-900 dark:text-white">0</div>
    </div>
    <div class="card rounded-xl border border-l-4 border-gray-200 border-l-blue-400 bg-white p-4 shadow-lg dark:border-gray-700 dark:bg-gray-800">
      <div class="mb-1 text-sm text-gray-600 dark:text-gray-400">High Priority</div>
      <div id="stat-high" class="text-2xl font-bold text-gray-900 dark:text-white">0</div>
    </div>
    <div class="card rounded-xl border border-l-4 border-gray-200 border-l-blue-400 bg-white p-4 shadow-lg dark:border-gray-700 dark:bg-gray-800">
      <div class="mb-1 text-sm text-gray-600 dark:text-gray-400">Total Size</div>
      <div id="stat-size" class="text-2xl font-bold text-gray-900 dark:text-white">0 KB</div>
    </div>
  </div>
  <!--END: Stats Cards -->
  <!--BEGIN: Batch Toolbar -->
  <div id="batch-toolbar" class="mb-4 hidden rounded-lg border border-blue-200 bg-blue-50 p-3 dark:border-blue-800 dark:bg-blue-900/20">
    <div class="flex flex-wrap items-center justify-between">
      <div class="flex items-center">
        <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">
          <span id="selected-count">0</span> selected </span>
        <button id="deselect-all-btn" class="ms-3 text-xs text-blue-600 hover:underline dark:text-blue-400">Clear selection</button>
      </div>
      <div class="flex items-center">
        <button id="batch-mark-read-btn" class="rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:hover:bg-gray-600">Mark as Read</button>
        <button id="batch-delete-btn" class="ms-2 rounded-md bg-red-600 px-3 py-1.5 text-sm text-white hover:bg-red-700">Delete Selected</button>
      </div>
    </div>
  </div>
  <!--END: Batch Toolbar -->
  <!--BEGIN: Mail List -->
  <div class="card rounded-lg border border-gray-200 shadow-lg dark:border-gray-700">
    <div class="card-header border-b border-gray-200 p-4 dark:border-gray-700">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-2">
          <input type="checkbox" id="select-all-checkbox" title="Select all on page" />
          <h2 class="ms-3 text-lg font-semibold text-gray-900 dark:text-white">Messages</h2>
        </div>
        <div class="flex items-center">
          <span class="text-sm text-gray-600 dark:text-gray-400 ml-2" id="mail-count">0 messages</span>
        </div>
      </div>
    </div>
    <div class="p-0">
      <ol id="mail-list" class="divide-y divide-gray-200 dark:divide-gray-700"></ol>
      <div id="no-mail" class="hidden p-8 text-center text-gray-500 dark:text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-4 opacity-50">
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
        <p>No system mail found</p>
      </div>
    </div>
    <div id="pagination-controls" class="hidden border-t border-gray-200 p-4 dark:border-gray-700">
      <div class="flex flex-wrap items-center justify-between">
        <div class="text-sm text-gray-600 dark:text-gray-400">Showing <span id="page-showing" class="font-semibold">1-20</span> of <span id="page-total" class="font-semibold">0</span>
        </div>
        <div class="flex items-center space-x-2">
          <button id="prev-page-btn" class="flex items-center rounded-md bg-gray-700 p-2 text-sm text-white hover:bg-gray-600 disabled:cursor-not-allowed disabled:opacity-50 dark:bg-gray-600 dark:hover:bg-gray-500" disabled>
            <svg class="me-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
          </button>
          <div class="space-x-2 flex items-center">
            <span class="text-sm text-gray-700 dark:text-gray-300">Page</span>
            <span id="current-page" class="mx-2 rounded-md bg-blue-600 px-3 py-1.5 text-sm font-semibold text-white">1</span>
            <span class="text-sm text-gray-700 dark:text-gray-300">of</span>
            <span id="total-pages" class="ms-2 rounded-md bg-gray-200 px-3 py-1.5 text-sm font-semibold text-gray-900 dark:bg-gray-700 dark:text-white">1</span>
          </div>
          <button id="next-page-btn" class="flex items-center rounded-md bg-blue-600 p-2 text-sm text-white hover:bg-blue-700 disabled:cursor-not-allowed disabled:opacity-50">
            <svg class="ms-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
  <!--END: Mail List -->
  <!--BEGIN: Mail Modal -->
  <div id="mail-modal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="flex min-h-full items-center justify-center p-4">
      <div class="relative flex h-full max-h-[90vh] w-full max-w-6xl flex-col overflow-hidden rounded-lg bg-white shadow-xl dark:bg-gray-800">
        <div class="flex items-center justify-between border-b border-gray-200 p-4 dark:border-gray-700">
          <div class="min-w-0">
            <h3 id="modal-subject" class="truncate text-base font-normal text-gray-800 dark:text-white"></h3>
            <p id="modal-from" class="truncate text-sm text-gray-600 dark:text-gray-400"></p>
          </div>
          <div class="ms-2 flex items-center">
            <button id="copy-email-btn" class="rounded-lg p-2 bg-blue-700 text-white hover:bg-gray-100" title="Copy">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
            </button>
            <button id="close-modal-btn" class="ms-1 rounded-lg p-2 text-gray-600 dark:text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
        </div>
        <div class="flex-1 overflow-y-auto p-4">
          <div class="mb-4 text-sm text-gray-600 dark:text-gray-400">
            <div>
              <strong>From:</strong>
              <span id="modal-from-full"></span>
            </div>
            <div>
              <strong>Date:</strong>
              <span id="modal-date"></span>
            </div>
            <div>
              <strong>Size:</strong>
              <span id="modal-size"></span>
            </div>
          </div>
          <div class="rounded-lg bg-gray-50 p-2 dark:bg-gray-900">
            <pre id="modal-body" class="bg-gray-50 dark:bg-gray-800 text-gray-700 dark:text-white font-mono text-xs sm:text-base whitespace-pre-wrap break-all overflow-x-hidden min-w-0 p-4 rounded-lg"></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!--END: Mail Modal -->
  <!--BEGIN: Delete Confirmation Modal -->
  <div id="delete-confirm-modal" class="fixed inset-0 z-50 hidden overflow-y-auto bg-black/50 backdrop-blur-sm">
    <div class="flex min-h-screen items-center justify-center p-4">
      <div class="relative w-full max-w-md rounded-lg border border-gray-200 bg-white shadow-xl dark:border-gray-700 dark:bg-gray-800">
        <div class="p-6 text-center">
          <h3 class="mb-2 text-lg font-semibold text-gray-900 dark:text-white">Confirm Deletion</h3>
          <p id="delete-confirm-message" class="mb-6 text-sm text-gray-600 dark:text-gray-400">Are you sure you want to delete this message?</p>
          <div class="flex justify-center">
            <button id="delete-cancel-btn" class="rounded-md bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200">Cancel</button>
            <button id="delete-confirm-btn" class="ms-3 rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700">Delete</button>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!--END: Delete Confirmation Modal -->
</div>
<!--END: Mail View Wrapper -->
